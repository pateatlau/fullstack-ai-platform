# Python Backend Environment Variables - Required and Optional

# REQUIRED: Which LLM provider to use
# Must be one of: openai, gemini, groq, anthropic
LLM_PROVIDER=openai

# CONDITIONAL: OpenAI API key
# Required if LLM_PROVIDER=openai, otherwise optional
OPENAI_API_KEY=

# CONDITIONAL: Gemini API key
# Required if LLM_PROVIDER=gemini, otherwise optional
GEMINI_API_KEY=

# CONDITIONAL: Groq API key
# Required if LLM_PROVIDER=groq, otherwise optional
GROQ_API_KEY=

# CONDITIONAL: Anthropic API key
# Required if LLM_PROVIDER=anthropic, otherwise optional
ANTHROPIC_API_KEY=

# Optional: OpenAI model identifier
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: Gemini model identifier
# Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: Groq model identifier
# Default: openai/gpt-oss-20b
GROQ_MODEL=openai/gpt-oss-20b

# Optional: Anthropic model identifier
# Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: Application environment
# Default: development
APP_ENV=development

# Optional: CORS allowed origins (comma-separated)
# Default: http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: Maximum message length in characters
# Default: 4000
MAX_MESSAGE_LENGTH=4000

# Optional: PostgreSQL connection string (async driver)
# Default: postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot

# CONDITIONAL: Google OAuth 2.0 client id
# Required to serve POST /api/auth/google (Google ID-token verification)
GOOGLE_CLIENT_ID=

# Optional: App JWT signing secret (MUST be overridden outside local dev)
# Default: dev-insecure-jwt-secret-change-me
JWT_SECRET=dev-insecure-jwt-secret-change-me

# Optional: App JWT algorithm
# Default: HS256
JWT_ALGORITHM=HS256

# Optional: App JWT access-token lifetime in minutes
# Default: 60
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Optional: Guest daily message quota (anonymous callers only)
# Default: 20
GUEST_DAILY_MESSAGE_QUOTA=20

# Optional: Feature flag to persist the chat lifecycle (sessions/messages/usage)
# When false, chat endpoints behave statelessly. Default: true
CHAT_PERSISTENCE_ENABLED=true

# Optional: Request timeout in seconds
# Default: 30
REQUEST_TIMEOUT_SECONDS=30

# Optional: Python logging buffering (set to 1 for unbuffered output in containers)
# Default: (empty - buffered)
PYTHONUNBUFFERED=1
