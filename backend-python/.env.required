# Python Backend Environment Variables - Required and Optional

# REQUIRED: Which LLM provider to use
# Must be one of: openai, gemini, groq, anthropic
LLM_PROVIDER=openai

# CONDITIONAL: OpenAI API key
# Required if LLM_PROVIDER=openai, otherwise optional
OPENAI_API_KEY=

# CONDITIONAL: Gemini API key
# Required if LLM_PROVIDER=gemini, otherwise optional
GEMINI_API_KEY=

# CONDITIONAL: Groq API key
# Required if LLM_PROVIDER=groq, otherwise optional
GROQ_API_KEY=

# CONDITIONAL: Anthropic API key
# Required if LLM_PROVIDER=anthropic, otherwise optional
ANTHROPIC_API_KEY=

# Optional: OpenAI model identifier
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: Gemini model identifier
# Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: Groq model identifier
# Default: openai/gpt-oss-20b
GROQ_MODEL=openai/gpt-oss-20b

# Optional: Anthropic model identifier
# Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: Application environment
# Default: development
APP_ENV=development

# Optional: Log level
# Default: INFO
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: CORS allowed origins (comma-separated)
# Default: http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: Maximum message length in characters
# Default: 4000
MAX_MESSAGE_LENGTH=4000

# Optional: Request timeout in seconds
# Default: 30
REQUEST_TIMEOUT_SECONDS=30

# Optional: Maximum request body size in bytes
# Default: 16384
REQUEST_BODY_LIMIT_BYTES=16384

# Optional: HTTP rate limit for anonymous callers (requests per minute)
# Default: 30
RATE_LIMIT_ANONYMOUS_PER_MINUTE=30

# Optional: HTTP rate limit for authenticated callers (requests per minute)
# Default: 120
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=120

# Optional: PostgreSQL connection string (async driver)
# Default: postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
# REQUIRED when APP_ENV is not development
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot

# CONDITIONAL: Google OAuth 2.0 client id
# Required to serve POST /api/auth/google (Google ID-token verification)
# REQUIRED when APP_ENV is not development
GOOGLE_CLIENT_ID=

# Optional: App JWT signing secret (MUST be overridden outside local dev)
# Default: dev-insecure-jwt-secret-change-me
JWT_SECRET=dev-insecure-jwt-secret-change-me

# Optional: App JWT algorithm
# Default: HS256
JWT_ALGORITHM=HS256

# Optional: App JWT access-token lifetime in minutes
# Default: 60
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Optional: Guest daily message quota (anonymous callers only)
# Default: 20
GUEST_DAILY_MESSAGE_QUOTA=20

# Optional: Feature flag to persist the chat lifecycle (sessions/messages/usage)
# When false, chat endpoints behave statelessly. Default: true
CHAT_PERSISTENCE_ENABLED=true

# Optional: Embedding provider for RAG (V1: openai only)
# Default: openai
EMBEDDING_PROVIDER=openai

# Optional: Embedding model identifier
# Default: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Embedding vector dimensions (must match model)
# Default: 1536
EMBEDDING_DIMENSIONS=1536

# Optional: Embedding batch size for document ingestion
# Default: 100
EMBEDDING_BATCH_SIZE=100

# Optional: Target chunk size for document ingestion
# Default: 1000
CHUNK_SIZE=1000

# Optional: Overlap between consecutive chunks
# Default: 200
CHUNK_OVERLAP=200

# Optional: Number of chunks retrieved for RAG
# Default: 5
RAG_TOP_K=5

# Optional: Default RAG prompt template (category/name/version)
# Default: rag/answer/v1
RAG_DEFAULT_PROMPT_TEMPLATE=rag/answer/v1

# Optional: Maximum RAG context size in characters
# Default: 8000
RAG_CONTEXT_MAX_CHARS=8000

# Optional: Feature flag for RAG endpoints and pipeline
# Default: false
RAG_ENABLED=false

# Optional: Feature flag for tool execution
# Default: false
TOOLS_ENABLED=false

# Optional: Feature flag for chat streaming (SSE). When false, use POST /api/chat.
# Default: true
CHAT_STREAMING_ENABLED=true

# Optional: Default LLM temperature for AI services
# Default: 0.7
DEFAULT_TEMPERATURE=0.7

# Optional: Default LLM max tokens (empty = provider default)
# Default: (empty)
DEFAULT_MAX_TOKENS=

# Optional: Maximum document upload size in bytes
# Default: 10485760 (10 MB)
DOCUMENT_UPLOAD_MAX_BYTES=10485760

# Optional: Web search provider for tools
# Default: tavily
WEB_SEARCH_PROVIDER=tavily

# CONDITIONAL: Web search API key
# Required when TOOLS_ENABLED=true, otherwise optional
WEB_SEARCH_API_KEY=

# Optional: Maximum web search results per query
# Default: 5
WEB_SEARCH_MAX_RESULTS=5

# Note: When RAG_ENABLED=true, OPENAI_API_KEY is required if EMBEDDING_PROVIDER=openai
# (even when LLM_PROVIDER is not openai).

# Optional: Python logging buffering (set to 1 for unbuffered output in containers)
# Default: (empty - buffered)
PYTHONUNBUFFERED=1
