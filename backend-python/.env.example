LLM_PROVIDER=openai            # openai | gemini | groq | anthropic (default LLM for chat and RAG when request omits provider)
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=gm-placeholder
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=gsk-placeholder
GROQ_MODEL=openai/gpt-oss-20b
ANTHROPIC_API_KEY=anthropic-placeholder
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_ENV=development
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
MAX_MESSAGE_LENGTH=4000
REQUEST_TIMEOUT_SECONDS=30
REQUEST_BODY_LIMIT_BYTES=16384
# HTTP rate limits (requests per minute; health endpoints exempt)
RATE_LIMIT_ANONYMOUS_PER_MINUTE=30
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=120
# PostgreSQL connection (async driver). Matches docker-compose defaults.
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
# Google OAuth 2.0 client id used to verify ID tokens (required for /api/auth/google)
GOOGLE_CLIENT_ID=
# App JWT signing (override JWT_SECRET outside local development)
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
# Guest quota: max messages per UTC day for anonymous callers
GUEST_DAILY_MESSAGE_QUOTA=20
# Feature flag: persist chat sessions/messages/usage (off => stateless chat)
CHAT_PERSISTENCE_ENABLED=true
# --- AI / RAG configuration (Phase 1; optional — safe defaults when omitted) ---
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# Optional: Embedding batch size for document ingestion
# EMBEDDING_BATCH_SIZE=100
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# RAG_TOP_K=5
# RAG_DEFAULT_PROMPT_TEMPLATE=rag/answer/v1
# RAG_CONTEXT_MAX_CHARS=8000
# RAG_ENABLED=false
# Gates document grounding toggle (use_documents on POST /api/chat[/stream]) and POST /api/rag/ask.
# Per-request provider/model override on POST /api/rag/ask and chat (optional provider, model fields).
# When omitted, RAG uses LLM_PROVIDER and the matching default model env var above.
# TOOLS_ENABLED=false
# Gates web search toggle (use_web_search on POST /api/chat[/stream]); registers Tavily web_search tool.
# CHAT_STREAMING_ENABLED=true
# Default true — SSE via POST /api/chat/stream. When false, stream route returns 503; UI uses POST /api/chat.
# Request toggles use_web_search / use_documents are JSON body fields (not env vars); require auth; default false.
# DEFAULT_TEMPERATURE=0.7
# DEFAULT_MAX_TOKENS=
# DOCUMENT_UPLOAD_MAX_BYTES=10485760  # enforced on POST /api/documents/upload (Phase 11)
# WEB_SEARCH_PROVIDER=tavily
# Required when TOOLS_ENABLED=true (Tavily web search)
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_MAX_RESULTS=5
